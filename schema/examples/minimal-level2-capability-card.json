{
  "$schema": "https://causalagentprotocol.org/schema/capability-card/v0.3.0.json",
  "name": "Example CAP Level 2 Server",
  "description": "Minimal Level 2 capability card for the active public CAP v0.3.0 intervention surface.",
  "version": "0.1.0",
  "cap_spec_version": "0.3.0",
  "provider": {
    "name": "Example Org",
    "url": "https://example.com"
  },
  "endpoint": "https://example.com/cap",
  "conformance_level": 2,
  "conformance_name": "Intervene",
  "supported_verbs": {
    "core": [
      "meta.capabilities",
      "meta.methods",
      "observe.predict",
      "intervene.do",
      "graph.neighbors",
      "graph.markov_blanket",
      "graph.paths"
    ],
    "convenience": [
      "traverse.parents",
      "traverse.children"
    ],
    "extensions": []
  },
  "causal_engine": {
    "family": "scm",
    "algorithm": "Linear SCM",
    "discovery_method": "structural_equation_fitting",
    "supports_time_lag": true,
    "supports_latent_variables": false,
    "supports_nonlinear": false,
    "supports_instantaneous": false,
    "structural_mechanisms": {
      "available": true,
      "families": [
        "linear_scm"
      ],
      "nodes_with_fitted_mechanisms": 10,
      "residuals_computable": true,
      "residual_semantics": "additive",
      "mechanism_override_supported": false,
      "counterfactual_ready": false
    }
  },
  "detailed_capabilities": {
    "graph_discovery": false,
    "graph_traversal": true,
    "temporal_multi_lag": true,
    "effect_estimation": true,
    "intervention_simulation": true,
    "counterfactual_scm": false,
    "latent_confounding_modeled": false,
    "partial_identification": false,
    "uncertainty_quantified": false
  },
  "assumptions": [
    "causal_sufficiency",
    "faithfulness",
    "mechanism_invariance_under_intervention"
  ],
  "reasoning_modes_supported": [
    "observational_prediction",
    "identified_causal_effect",
    "graph_propagation",
    "structural_semantics"
  ],
  "graph": {
    "domains": [
      "warehouse-operations"
    ],
    "node_count": 10,
    "edge_count": 18,
    "node_types": [
      "metric"
    ],
    "edge_types_supported": [
      "directed_lagged"
    ],
    "graph_representation": "time_lagged_dag",
    "update_frequency": "PT24H",
    "temporal_resolution": "PT1H",
    "coverage_description": "Small operational SCM used for a Level 2 example."
  },
  "authentication": {
    "type": "none",
    "details": {}
  }
}

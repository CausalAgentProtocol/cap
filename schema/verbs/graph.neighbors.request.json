{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalagentprotocol.org/schema/verbs/graph.neighbors.request.json",
  "title": "graph.neighbors request",
  "$comment": "Supports the current public CAP request shape plus the older direction/top_k legacy shape kept for compatibility review.",
  "anyOf": [
    {
      "$ref": "#/$defs/current_request"
    },
    {
      "$ref": "#/$defs/legacy_request"
    }
  ],
  "$defs": {
    "current_params": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "$ref": "../shared/enums.json#/$defs/graph_neighbor_scope"
        },
        "max_neighbors": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "node_id",
        "scope"
      ],
      "unevaluatedProperties": false
    },
    "legacy_params": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "$ref": "../shared/enums.json#/$defs/graph_direction"
        },
        "top_k": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "node_id",
        "direction"
      ],
      "unevaluatedProperties": false
    },
    "current_request": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/request_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            },
            "params": {
              "$ref": "#/$defs/current_params"
            }
          },
          "required": [
            "verb",
            "params"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "legacy_request": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/request_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            },
            "params": {
              "$ref": "#/$defs/legacy_params"
            }
          },
          "required": [
            "verb",
            "params"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

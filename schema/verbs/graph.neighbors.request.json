{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalagentprotocol.org/schema/verbs/graph.neighbors.request.json",
  "title": "graph.neighbors request",
  "$comment": "The draft request shape adds sort_by and include_values over the current public adapter model. Both forms are accepted here.",
  "anyOf": [
    {
      "$ref": "#/$defs/draft_request"
    },
    {
      "$ref": "#/$defs/current_adapter_request"
    }
  ],
  "$defs": {
    "draft_params": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "$ref": "../shared/enums.json#/$defs/graph_direction"
        },
        "top_k": {
          "type": "integer",
          "minimum": 0
        },
        "sort_by": {
          "$ref": "../shared/enums.json#/$defs/neighbor_sort_by"
        },
        "include_values": {
          "type": "boolean"
        }
      },
      "required": [
        "node_id",
        "direction"
      ],
      "unevaluatedProperties": false
    },
    "current_adapter_params": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "$ref": "../shared/enums.json#/$defs/graph_direction"
        },
        "top_k": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "node_id",
        "direction"
      ],
      "unevaluatedProperties": false
    },
    "draft_request": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/request_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            },
            "params": {
              "$ref": "#/$defs/draft_params"
            }
          },
          "required": [
            "verb",
            "params"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "current_adapter_request": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/request_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            },
            "params": {
              "$ref": "#/$defs/current_adapter_params"
            }
          },
          "required": [
            "verb",
            "params"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

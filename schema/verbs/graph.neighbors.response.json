{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalagentprotocol.org/schema/verbs/graph.neighbors.response.json",
  "title": "graph.neighbors response",
  "$comment": "Supports the current public CAP response shape plus the older legacy shape kept for compatibility review.",
  "anyOf": [
    {
      "$ref": "#/$defs/current_success_response"
    },
    {
      "$ref": "#/$defs/legacy_success_response"
    },
    {
      "$ref": "#/$defs/error_response"
    }
  ],
  "$defs": {
    "current_neighbor": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "../shared/enums.json#/$defs/graph_neighbor_role"
          },
          "uniqueItems": true
        }
      },
      "required": [
        "node_id",
        "roles"
      ],
      "unevaluatedProperties": false
    },
    "current_result": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "$ref": "../shared/enums.json#/$defs/graph_neighbor_scope"
        },
        "neighbors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/current_neighbor"
          }
        },
        "total_candidate_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "edge_semantics": {
          "type": [
            "string",
            "null"
          ]
        },
        "reasoning_mode": {
          "$ref": "../shared/enums.json#/$defs/reasoning_mode"
        },
        "identification_status": {
          "$ref": "../shared/enums.json#/$defs/identification_status"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "node_id",
        "scope",
        "neighbors",
        "truncated",
        "reasoning_mode",
        "identification_status",
        "assumptions"
      ],
      "unevaluatedProperties": false
    },
    "legacy_neighbor": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "relationship": {
          "$ref": "../shared/enums.json#/$defs/neighbor_relationship"
        }
      },
      "required": [
        "node_id",
        "relationship"
      ],
      "unevaluatedProperties": false
    },
    "legacy_result": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "$ref": "../shared/enums.json#/$defs/graph_direction"
        },
        "neighbors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legacy_neighbor"
          }
        },
        "reasoning_mode": {
          "type": "string",
          "minLength": 1
        },
        "identification_status": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "node_id",
        "direction",
        "neighbors",
        "reasoning_mode",
        "identification_status",
        "assumptions"
      ],
      "unevaluatedProperties": false
    },
    "current_success_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/success_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            },
            "result": {
              "$ref": "#/$defs/current_result"
            }
          },
          "required": [
            "verb",
            "result"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "legacy_success_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/success_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            },
            "result": {
              "$ref": "#/$defs/legacy_result"
            }
          },
          "required": [
            "verb",
            "result"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "error_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/error_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "graph.neighbors"
            }
          },
          "required": [
            "verb"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

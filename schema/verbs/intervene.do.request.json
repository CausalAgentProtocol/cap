{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalagentprotocol.org/schema/verbs/intervene.do.request.json",
  "title": "intervene.do request",
  "$comment": "Supports the current public CAP intent-only request shape plus the older richer draft shape kept for compatibility review.",
  "anyOf": [
    {
      "$ref": "#/$defs/current_request"
    },
    {
      "$ref": "#/$defs/legacy_request"
    }
  ],
  "$defs": {
    "legacy_intervention": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "$ref": "../shared/enums.json#/$defs/intervention_unit"
        }
      },
      "required": [
        "node_id",
        "value",
        "unit"
      ],
      "unevaluatedProperties": false
    },
    "legacy_params": {
      "type": "object",
      "properties": {
        "interventions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legacy_intervention"
          },
          "minItems": 1
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "horizon": {
          "type": "string",
          "minLength": 1
        },
        "include_paths": {
          "type": "boolean"
        }
      },
      "required": [
        "interventions",
        "targets"
      ],
      "unevaluatedProperties": false
    },
    "current_params": {
      "type": "object",
      "properties": {
        "treatment_node": {
          "type": "string",
          "minLength": 1
        },
        "treatment_value": {
          "type": "number"
        },
        "outcome_node": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "treatment_node",
        "treatment_value",
        "outcome_node"
      ],
      "unevaluatedProperties": false
    },
    "current_request": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/request_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "intervene.do"
            },
            "params": {
              "$ref": "#/$defs/current_params"
            }
          },
          "required": [
            "verb",
            "params"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "legacy_request": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/request_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "intervene.do"
            },
            "params": {
              "$ref": "#/$defs/legacy_params"
            }
          },
          "required": [
            "verb",
            "params"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalagentprotocol.org/schema/verbs/intervene.do.response.json",
  "title": "intervene.do response",
  "$comment": "Supports the current public single-claim CAP response shape plus the older richer draft shape kept for compatibility review.",
  "anyOf": [
    {
      "$ref": "#/$defs/current_success_response"
    },
    {
      "$ref": "#/$defs/legacy_success_response"
    },
    {
      "$ref": "#/$defs/error_response"
    }
  ],
  "$defs": {
    "legacy_intervention": {
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "$ref": "../shared/enums.json#/$defs/intervention_unit"
        }
      },
      "required": [
        "node_id",
        "value",
        "unit"
      ],
      "unevaluatedProperties": false
    },
    "legacy_path_edge": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "edge_type": {
          "$ref": "../shared/enums.json#/$defs/graph_edge_type"
        },
        "tau": {
          "type": "integer"
        },
        "weight": {
          "type": "number"
        }
      },
      "required": [
        "from",
        "to",
        "edge_type",
        "tau",
        "weight"
      ],
      "unevaluatedProperties": false
    },
    "legacy_effect": {
      "type": "object",
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "expected_change": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "confidence_interval": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "interval_method": {
          "$ref": "../shared/enums.json#/$defs/interval_method"
        },
        "probability_positive": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "propagation_delay": {
          "type": "string",
          "minLength": 1
        },
        "reasoning_mode": {
          "$ref": "../shared/enums.json#/$defs/reasoning_mode"
        },
        "mechanism_coverage_complete": {
          "type": "boolean"
        },
        "causal_path": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legacy_path_edge"
          }
        }
      },
      "required": [
        "target",
        "expected_change",
        "unit",
        "probability_positive",
        "propagation_delay",
        "reasoning_mode"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "reasoning_mode": {
                "const": "scm_simulation"
              }
            },
            "required": [
              "reasoning_mode"
            ]
          },
          "then": {
            "required": [
              "mechanism_coverage_complete"
            ]
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "legacy_result": {
      "type": "object",
      "properties": {
        "interventions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legacy_intervention"
          },
          "minItems": 1
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legacy_effect"
          }
        },
        "identification_status": {
          "$ref": "../shared/enums.json#/$defs/identification_status"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "required": [
        "interventions",
        "effects",
        "identification_status",
        "assumptions"
      ],
      "unevaluatedProperties": false
    },
    "current_result": {
      "type": "object",
      "properties": {
        "treatment_node": {
          "type": "string",
          "minLength": 1
        },
        "treatment_value": {
          "type": "number"
        },
        "delta_unit": {
          "type": "string",
          "minLength": 1
        },
        "reasoning_mode": {
          "$ref": "../shared/enums.json#/$defs/reasoning_mode"
        },
        "outcome_node": {
          "type": "string",
          "minLength": 1
        },
        "identification_status": {
          "$ref": "../shared/enums.json#/$defs/identification_status"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "treatment_node",
        "treatment_value",
        "delta_unit",
        "reasoning_mode",
        "outcome_node",
        "identification_status",
        "assumptions"
      ],
      "unevaluatedProperties": false
    },
    "current_success_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/success_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "intervene.do"
            },
            "result": {
              "$ref": "#/$defs/current_result"
            }
          },
          "required": [
            "verb",
            "result"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "legacy_success_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/success_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "intervene.do"
            },
            "result": {
              "$ref": "#/$defs/legacy_result"
            }
          },
          "required": [
            "verb",
            "result"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "error_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/error_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "intervene.do"
            }
          },
          "required": [
            "verb"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

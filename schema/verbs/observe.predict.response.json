{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalagentprotocol.org/schema/verbs/observe.predict.response.json",
  "title": "observe.predict response",
  "anyOf": [
    {
      "$ref": "#/$defs/success_response"
    },
    {
      "$ref": "#/$defs/error_response"
    }
  ],
  "$defs": {
    "result": {
      "type": "object",
      "properties": {
        "target_node": {
          "type": "string",
          "minLength": 1
        },
        "prediction": {
          "type": "number"
        },
        "drivers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "target_node",
        "prediction",
        "drivers"
      ],
      "unevaluatedProperties": false
    },
    "success_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/success_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "observe.predict"
            },
            "result": {
              "$ref": "#/$defs/result"
            }
          },
          "required": [
            "verb",
            "result"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "error_response": {
      "allOf": [
        {
          "$ref": "../envelopes/v0.2.2.json#/$defs/error_response_envelope"
        },
        {
          "type": "object",
          "properties": {
            "verb": {
              "const": "observe.predict"
            }
          },
          "required": [
            "verb"
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

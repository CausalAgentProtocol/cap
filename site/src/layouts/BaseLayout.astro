---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import { ClientRouter } from "astro:transitions";
import { getSearchIndex, type SidebarGroup, type TocHeading } from "../lib/site";

interface Props {
  title: string;
  currentRoute: string;
  currentSection?: string;
  description?: string;
  sidebar?: SidebarGroup[];
  toc?: TocHeading[];
}

const { title, currentRoute, currentSection, description, sidebar = [], toc = [] } = Astro.props;
const routeClass = `route-${currentRoute.replace(/^\//, "").replace(/[^a-z0-9]+/gi, "-").replace(/^-+|-+$/g, "") || "home"}`;
const searchIndexJson = JSON.stringify(await getSearchIndex()).replace(/</g, "\\u003c");

const topNav = [
  {
    href: "/docs/overview",
    label: "Docs",
    active: currentSection === "documentation" || currentRoute === "/docs" || currentRoute.startsWith("/docs/")
  },
  {
    href: "/spec",
    label: "Spec",
    active: currentSection === "specification" || currentRoute === "/spec" || currentRoute.startsWith("/spec/")
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | CAP</title>
    <link rel="icon" type="image/svg+xml" href="/icons/cap-logo-c-sharp-transparent.svg" />
    <ClientRouter />
    <script id="site-search-index" type="application/json" set:html={searchIndexJson}></script>
    <script>
      const copySectionLink = async (trigger) => {
        const id = trigger.getAttribute("data-copy-id");

        if (!id) return;

        const url = new URL(window.location.href);
        url.hash = id;

        try {
          await navigator.clipboard.writeText(url.toString());
          trigger.classList.add("copied");
          window.setTimeout(() => trigger.classList.remove("copied"), 900);
        } catch {}
      };

      document.addEventListener("click", (event) => {
        const trigger = event.target instanceof Element ? event.target.closest("[data-copy-link]") : null;

        if (!(trigger instanceof HTMLAnchorElement)) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

        void copySectionLink(trigger);
      });

      const normalizeSearchText = (value) =>
        value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, " ")
          .trim();

      const escapeSearchHtml = (value) =>
        value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");

      const escapeSearchPattern = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

      const getSearchIndexData = () => {
        const node = document.getElementById("site-search-index");

        if (!(node instanceof HTMLScriptElement)) {
          return [];
        }

        try {
          return JSON.parse(node.textContent ?? "[]");
        } catch {
          return [];
        }
      };

      const buildSearchSnippet = (body, terms) => {
        const text = body.replace(/\s+/g, " ").trim();

        if (!text) {
          return "";
        }

        const lower = text.toLowerCase();
        const matchIndex = terms
          .map((term) => lower.indexOf(term))
          .filter((index) => index >= 0)
          .sort((left, right) => left - right)[0];

        const start = Math.max(0, (matchIndex ?? 0) - 42);
        const end = Math.min(text.length, start + 170);
        const prefix = start > 0 ? "..." : "";
        const suffix = end < text.length ? "..." : "";

        return `${prefix}${text.slice(start, end).trim()}${suffix}`;
      };

      const searchDocuments = (query, searchIndex) => {
        const normalizedQuery = normalizeSearchText(query);
        const terms = normalizedQuery.split(/\s+/).filter(Boolean);

        if (!terms.length) {
          return [];
        }

        return searchIndex
          .map((entry) => {
            const title = normalizeSearchText(entry.title);
            const route = normalizeSearchText(entry.route);
            const body = normalizeSearchText(entry.body);
            const combined = `${title} ${route} ${body}`;

            if (!terms.every((term) => combined.includes(term))) {
              return null;
            }

            let score = 0;

            for (const term of terms) {
              if (title === term) score += 50;
              if (title.startsWith(term)) score += 18;
              if (title.includes(term)) score += 10;
              if (route.includes(term)) score += 5;
              if (body.includes(term)) score += 2;
            }

            if (entry.section === "documentation") {
              score += 1;
            }

            return {
              ...entry,
              score,
              snippet: buildSearchSnippet(entry.body, terms)
            };
          })
          .filter(Boolean)
          .sort((left, right) => right.score - left.score || left.title.localeCompare(right.title))
          .slice(0, 8);
      };

      const searchContextLabel = (entry) => {
        if (entry.route.startsWith("/docs/quickstart")) return "Quickstart";
        if (entry.route.startsWith("/docs/concepts/")) return "Concept";
        if (entry.route.startsWith("/docs/guides/")) return "Guide";
        if (entry.route.startsWith("/docs/rationale/")) return "Rationale";
        if (entry.route === "/spec") return "Specification";
        if (entry.route.startsWith("/spec/")) return "Spec";
        return entry.section === "specification" ? "Spec" : "Docs";
      };

      const highlightSearchMatches = (value, terms) => {
        let rendered = escapeSearchHtml(value);

        for (const term of [...new Set(terms)].filter((candidate) => candidate.length > 1)) {
          rendered = rendered.replace(
            new RegExp(`(${escapeSearchPattern(term)})`, "gi"),
            '<mark class="site-search-mark">$1</mark>'
          );
        }

        return rendered;
      };

      const setSearchOpen = (root, isOpen) => {
        root.dataset.open = isOpen ? "true" : "false";

        const panel = root.querySelector("[data-search-panel]");

        if (panel instanceof HTMLElement) {
          panel.hidden = !isOpen;
        }
      };

      const renderSearchResults = (root, query, matches) => {
        const results = root.querySelector("[data-search-results]");
        const empty = root.querySelector("[data-search-empty]");
        const terms = normalizeSearchText(query).split(/\s+/).filter(Boolean);

        if (!(results instanceof HTMLElement) || !(empty instanceof HTMLElement)) {
          return;
        }

        if (!query.trim()) {
          results.innerHTML = "";
          empty.textContent = "Search by concept, verb, field name, or page title.";
          setSearchOpen(root, true);
          return;
        }

        if (!matches.length) {
          results.innerHTML = "";
          empty.textContent = `No pages mention "${query}".`;
          setSearchOpen(root, true);
          return;
        }

        empty.textContent = "";
        results.innerHTML = matches
          .map((entry) => {
            const contextLabel = searchContextLabel(entry);

            return `
              <a class="site-search-result" href="${entry.route}" data-search-result>
                <span class="site-search-meta">${contextLabel}</span>
                <span class="site-search-title">${highlightSearchMatches(entry.title, terms)}</span>
                <span class="site-search-snippet">${highlightSearchMatches(entry.snippet, terms)}</span>
              </a>
            `;
          })
          .join("");

        setSearchOpen(root, true);
      };

      const attachSiteSearch = () => {
        const searchIndex = getSearchIndexData();

        document.querySelectorAll("[data-site-search]").forEach((root) => {
          if (!(root instanceof HTMLElement) || root.dataset.searchBound === "true") {
            return;
          }

          const input = root.querySelector("[data-search-input]");

          if (!(input instanceof HTMLInputElement)) {
            return;
          }

          root.dataset.searchBound = "true";

          const updateResults = () => {
            renderSearchResults(root, input.value, searchDocuments(input.value, searchIndex));
          };

          input.addEventListener("input", updateResults);
          input.addEventListener("focus", updateResults);
          input.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
              setSearchOpen(root, false);
              input.blur();
              return;
            }

            if (event.key === "ArrowDown") {
              const firstResult = root.querySelector("[data-search-result]");

              if (firstResult instanceof HTMLAnchorElement) {
                event.preventDefault();
                firstResult.focus();
              }
            }

            if (event.key === "Enter") {
              const firstResult = root.querySelector("[data-search-result]");

              if (firstResult instanceof HTMLAnchorElement && input.value.trim()) {
                event.preventDefault();
                window.location.assign(firstResult.href);
              }
            }
          });
        });
      };

      if (!window.__capSiteSearchBound) {
        window.__capSiteSearchBound = true;

        document.addEventListener("click", (event) => {
          document.querySelectorAll("[data-site-search][data-open='true']").forEach((root) => {
            if (!(root instanceof HTMLElement) || root.contains(event.target)) {
              return;
            }

            setSearchOpen(root, false);
          });
        });

        document.addEventListener("keydown", (event) => {
          if (event.key !== "k" || (!event.metaKey && !event.ctrlKey)) {
            return;
          }

          const active = document.activeElement;

          if (active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement) {
            return;
          }

          const input = document.querySelector("[data-search-input]");

          if (input instanceof HTMLInputElement) {
            event.preventDefault();
            input.focus();
            input.select();
          }
        });

        document.addEventListener("astro:page-load", attachSiteSearch);
        document.addEventListener("DOMContentLoaded", attachSiteSearch);
      }

      attachSiteSearch();
    </script>
    <style>
      :root {
        --bg: #ffffff;
        --surface: #f5f5f5;
        --surface-strong: #efefef;
        --ink: #111111;
        --muted: #686868;
        --accent: #111111;
        --accent-soft: #f0f0f0;
        --shadow: 0 18px 44px rgba(0, 0, 0, 0.06);
        --masthead-height: 3.8rem;
        --frame-max-width: 1400px;
        --frame-gutter: 1rem;
        --content-inline-padding: 1.5rem;
        --sidebar-width: 240px;
        --font-size-caption: 0.75rem;
        --font-size-label: 0.8125rem;
        --font-size-nav: 0.9375rem;
        --font-size-body: 1rem;
        --font-size-body-strong: 1rem;
        --font-size-sidebar: 0.9375rem;
        --font-size-title-sm: 1.125rem;
        --font-size-title-md: 1.375rem;
        --font-size-display: clamp(1.9rem, 3.6vw, 2.65rem);
        --font-weight-regular: 400;
        --font-weight-medium: 500;
        --font-weight-semibold: 600;
        --line-height-tight: 1.15;
        --line-height-heading: 1.22;
        --line-height-body: 1.58;
        --tracking-label: 0.08em;
        --tracking-tight: -0.025em;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 16px;
        line-height: var(--line-height-body);
        scroll-padding-top: calc(var(--masthead-height) + 1rem);
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        margin: 0;
      }

      a {
        color: inherit;
      }

      .shell {
        min-height: 100vh;
        padding: calc(var(--masthead-height) + 1.25rem) 0 2rem;
      }

      .frame {
        width: min(var(--frame-max-width), calc(100% - (2 * var(--frame-gutter))));
        margin: 0 auto;
        min-height: 100vh;
        background: var(--bg);
      }

      .masthead {
        position: fixed;
        top: 0;
        left: 50%;
        z-index: 40;
        width: min(var(--frame-max-width), calc(100% - (2 * var(--frame-gutter))));
        min-height: var(--masthead-height);
        padding: 0 var(--content-inline-padding);
        transform: translateX(-50%);
        border-bottom: 1px solid rgba(17, 17, 17, 0.08);
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(14px);
      }

      .masthead-top {
        display: grid;
        grid-template-columns: minmax(max-content, 1fr) minmax(19rem, 34rem) minmax(max-content, 1fr);
        gap: 1.25rem;
        align-items: center;
        min-height: var(--masthead-height);
      }

      .brand {
        justify-self: start;
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
        color: var(--ink);
        font-size: 0.9375rem;
        font-weight: var(--font-weight-medium);
        letter-spacing: -0.01em;
      }

      .brand-mark {
        flex: 0 0 auto;
        width: 1.15rem;
        height: 1.15rem;
        display: block;
      }

      .brand-wordmark {
        white-space: nowrap;
      }

      .nav {
        display: flex;
        justify-self: end;
        flex: 0 0 auto;
        align-self: stretch;
        align-items: stretch;
        justify-content: flex-end;
        gap: 0.25rem;
        overflow-x: auto;
        scrollbar-width: none;
      }

      .nav::-webkit-scrollbar {
        display: none;
      }

      .nav a {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        height: 100%;
        padding: 0 0.95rem;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        background: transparent;
        color: var(--muted);
        font-size: var(--font-size-nav);
        font-weight: var(--font-weight-regular);
        letter-spacing: -0.01em;
        white-space: nowrap;
      }

      .nav a[data-active="true"] {
        color: var(--accent);
        border-bottom-color: var(--accent);
        font-weight: var(--font-weight-medium);
      }

      .site-search {
        position: relative;
        justify-self: center;
        width: 100%;
        max-width: 34rem;
        min-width: 19rem;
      }

      .site-search-input {
        width: 100%;
        height: 2.65rem;
        padding: 0 1rem;
        border: 1px solid rgba(17, 17, 17, 0.12);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.96);
        color: var(--ink);
        font: inherit;
        font-size: 0.96rem;
        letter-spacing: -0.015em;
        outline: none;
        transition:
          border-color 160ms ease,
          box-shadow 160ms ease,
          background-color 160ms ease;
      }

      .site-search-input::placeholder {
        color: #7a7a7a;
      }

      .site-search[data-open="true"] .site-search-input,
      .site-search-input:focus {
        border-color: rgba(17, 17, 17, 0.22);
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(17, 17, 17, 0.04);
      }

      .site-search-panel {
        position: absolute;
        top: calc(100% + 0.55rem);
        left: 50%;
        width: min(34rem, calc(100vw - 2rem));
        max-height: min(26rem, calc(100vh - 6rem));
        overflow-y: auto;
        padding: 0.5rem;
        border: 1px solid rgba(17, 17, 17, 0.1);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.985);
        box-shadow: 0 30px 60px rgba(17, 17, 17, 0.12);
        transform: translateX(-50%);
      }

      .site-search-empty {
        padding: 0.85rem 0.95rem;
        color: var(--muted);
        font-size: 0.86rem;
        letter-spacing: -0.01em;
      }

      .site-search-results {
        display: grid;
        gap: 0.35rem;
      }

      :global(.site-search-result) {
        display: block;
        padding: 0.82rem 0.95rem 0.88rem;
        border: 1px solid rgba(17, 17, 17, 0.05);
        border-radius: 16px;
        background: #ffffff;
        text-decoration: none;
      }

      :global(.site-search-result:hover),
      :global(.site-search-result:focus-visible) {
        border-color: rgba(17, 17, 17, 0.12);
        background: #fbfbfb;
        outline: none;
        box-shadow: 0 10px 22px rgba(17, 17, 17, 0.06);
      }

      :global(.site-search-meta) {
        display: block;
        margin-bottom: 0.24rem;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: var(--font-weight-medium);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      :global(.site-search-title) {
        display: block;
        color: var(--ink);
        font-size: 0.97rem;
        font-weight: var(--font-weight-medium);
        line-height: 1.35;
        letter-spacing: -0.016em;
      }

      :global(.site-search-snippet) {
        display: block;
        margin-top: 0.28rem;
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.5;
        letter-spacing: -0.012em;
      }

      :global(.site-search-mark) {
        padding: 0.02rem 0.22rem;
        border-radius: 0.35rem;
        background: rgba(17, 17, 17, 0.08);
        color: inherit;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .masthead-copy {
        display: none;
      }

      .content {
        display: grid;
        grid-template-columns: var(--sidebar-width) minmax(0, 1fr) 220px;
        gap: 2rem;
        padding: 0 var(--content-inline-padding) 2.75rem;
      }

      .content[data-left="false"] {
        grid-template-columns: minmax(0, 1fr) 220px;
      }

      .content[data-right="false"] {
        grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
      }

      .content[data-left="false"][data-right="false"] {
        grid-template-columns: minmax(0, 1fr);
      }

      .source {
        display: inline-flex;
        margin-bottom: 1rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: var(--surface);
        color: var(--muted);
        font-size: var(--font-size-caption);
        font-weight: var(--font-weight-medium);
        letter-spacing: 0.01em;
      }

      .sidebar {
        align-self: start;
        padding: 1rem 0 0;
      }

      .sidebar-scroll {
        position: fixed;
        top: calc(var(--masthead-height) + 1rem);
        left: max(
          calc(50vw - (var(--frame-max-width) / 2) + var(--content-inline-padding)),
          calc(var(--frame-gutter) + var(--content-inline-padding))
        );
        width: calc(var(--sidebar-width) - 0.4rem);
        max-height: calc(100vh - var(--masthead-height) - 1.5rem);
        overflow-y: auto;
        overscroll-behavior: contain;
        padding-right: 0.4rem;
        scrollbar-width: thin;
      }

      .sidebar-group + .sidebar-group {
        margin-top: 1.25rem;
      }

      .sidebar-group h2 {
        margin: 0 0 0.45rem;
        color: var(--muted);
        font-size: var(--font-size-label);
        font-weight: var(--font-weight-semibold);
        letter-spacing: var(--tracking-label);
        text-transform: uppercase;
      }

      .sidebar-group a {
        display: block;
        text-decoration: none;
        padding: 0.45rem 0.65rem;
        border-radius: 0.8rem;
        color: var(--muted);
        font-size: var(--font-size-sidebar);
        font-weight: var(--font-weight-regular);
        line-height: 1.45;
        letter-spacing: -0.01em;
      }

      .sidebar-group a[data-active="true"] {
        background: var(--accent-soft);
        color: var(--ink);
        font-weight: var(--font-weight-medium);
      }

      .main {
        min-width: 0;
      }

      .toc {
        position: sticky;
        top: calc(var(--masthead-height) + 1rem);
        align-self: start;
        padding-top: 1rem;
      }

      .toc h2 {
        margin: 0 0 0.5rem;
        color: var(--muted);
        font-size: var(--font-size-label);
        font-weight: var(--font-weight-semibold);
        letter-spacing: var(--tracking-label);
        text-transform: uppercase;
      }

      .toc a {
        display: block;
        text-decoration: none;
        color: var(--muted);
        font-size: 0.875rem;
        font-weight: var(--font-weight-regular);
        line-height: 1.45;
        letter-spacing: -0.01em;
        padding: 0.35rem 0;
      }

      .toc a[data-depth="3"] {
        padding-left: 0.9rem;
      }

      .prose {
        max-width: 48rem;
      }

      :global(.prose :first-child) {
        margin-top: 0;
      }

      :global(.prose h1),
      :global(.prose h2),
      :global(.prose h3) {
        line-height: var(--line-height-heading);
        font-weight: var(--font-weight-medium);
        letter-spacing: -0.02em;
        scroll-margin-top: calc(var(--masthead-height) + 1rem);
      }

      :global(.prose h1) {
        font-size: var(--font-size-display);
      }

      :global(.prose h2) {
        margin-top: 1.65rem;
        padding-top: 0.25rem;
        font-size: var(--font-size-title-md);
      }

      :global(.prose h3) {
        margin-top: 1.2rem;
        font-size: var(--font-size-title-sm);
      }

      :global(.prose p),
      :global(.prose li) {
        font-size: var(--font-size-body-strong);
        font-weight: var(--font-weight-regular);
        line-height: var(--line-height-body);
        letter-spacing: -0.009em;
      }

      :global(.prose strong),
      :global(.prose b) {
        font-weight: var(--font-weight-semibold);
        letter-spacing: -0.012em;
      }

      :global(.prose p),
      :global(.prose ul),
      :global(.prose ol),
      :global(.prose pre) {
        margin-top: 0.8rem;
        margin-bottom: 0.8rem;
      }

      :global(.prose li + li) {
        margin-top: 0.18rem;
      }

      :global(.prose ul),
      :global(.prose ol) {
        padding-left: 1.2rem;
      }

      :global(.prose code) {
        padding: 0.12rem 0.35rem;
        border-radius: 0.35rem;
        background: var(--surface);
        font-size: 0.92em;
        font-weight: var(--font-weight-medium);
      }

      :global(.prose pre) {
        padding: 1rem;
        overflow-x: auto;
        border: 1px solid rgba(17, 17, 17, 0.14);
        border-radius: 18px;
        background: #ffffff;
        color: #1f2328;
        box-shadow: 0 1px 2px rgba(17, 17, 17, 0.04);
      }

      :global(.prose pre code) {
        background: transparent;
        padding: 0;
        color: inherit;
        font-weight: var(--font-weight-regular);
      }

      :global(.prose a) {
        color: var(--ink);
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.16em;
      }

      :global(.prose blockquote) {
        margin: 1rem 0;
        padding: 1rem 1.15rem;
        border-left: 2px solid rgba(17, 17, 17, 0.16);
        border-radius: 0 18px 18px 0;
        background: linear-gradient(180deg, rgba(17, 17, 17, 0.025), rgba(17, 17, 17, 0.01));
      }

      :global(.prose blockquote p) {
        margin: 0;
        font-size: 1.03rem;
        font-weight: var(--font-weight-medium);
        line-height: 1.45;
        letter-spacing: -0.014em;
      }

      :global(.prose .heading-anchor) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.2rem;
        height: 1.2rem;
        margin-left: 0.38rem;
        margin-inline-start: 0.5rem;
        border: none;
        border-radius: 999px;
        background: transparent;
        color: rgba(17, 17, 17, 0.28);
        padding: 0;
        font: inherit;
        line-height: 1;
        text-decoration: none;
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 160ms ease,
          color 160ms ease,
          transform 160ms ease;
        transform: translateY(0);
        vertical-align: middle;
      }

      :global(.prose h2:hover .heading-anchor),
      :global(.prose h3:hover .heading-anchor),
      :global(.prose .heading-anchor:hover),
      :global(.prose .heading-anchor:focus-visible) {
        opacity: 1;
        pointer-events: auto;
        color: rgba(17, 17, 17, 0.52);
        outline: none;
        transform: translateY(0);
      }

      :global(.prose .heading-anchor-icon) {
        width: 0.78rem;
        height: 0.78rem;
        background-color: currentColor;
        -webkit-mask-image: url("/icons/copy-link.svg");
        -webkit-mask-position: center;
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-size: contain;
        mask-image: url("/icons/copy-link.svg");
        mask-position: center;
        mask-repeat: no-repeat;
        mask-size: contain;
      }

      :global(.prose .heading-anchor.copied) {
        color: rgba(17, 17, 17, 0.56);
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3) {
        margin-top: 1.5rem;
        margin-bottom: 0;
        padding: 1.1rem 1.2rem 0.35rem;
        border: 1px solid rgba(17, 17, 17, 0.1);
        border-bottom: none;
        border-radius: 22px 22px 0 0;
        background: #ffffff;
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p) {
        margin-top: 0;
        margin-bottom: 0;
        padding: 0 1.2rem 1rem;
        border-left: 1px solid rgba(17, 17, 17, 0.1);
        border-right: 1px solid rgba(17, 17, 17, 0.1);
        background: #ffffff;
        color: rgba(17, 17, 17, 0.84);
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul) {
        margin-top: 0;
        margin-bottom: 1.15rem;
        padding: 0 1.2rem 1rem;
        list-style: none;
        border: 1px solid rgba(17, 17, 17, 0.1);
        border-top: none;
        border-radius: 0 0 22px 22px;
        background: #ffffff;
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul > li) {
        display: block;
        margin: 0;
        padding: 0.8rem 0;
        border-top: 1px solid rgba(17, 17, 17, 0.08);
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul > li:first-child) {
        padding-top: 0;
        border-top: none;
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul > li:last-child) {
        padding-bottom: 0;
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul > li > em:first-child) {
        display: inline-block;
        width: min(8rem, 100%);
        margin-right: 0.95rem;
        font-style: normal;
        font-size: 0.82rem;
        font-weight: var(--font-weight-medium);
        line-height: 1.7;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        vertical-align: top;
      }

      :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul code) {
        white-space: nowrap;
      }

      :global(body.route-docs-concepts-what-is-causality .prose ol) {
        padding-left: 1.35rem;
      }

      :global(body.route-docs-concepts-what-is-causality .prose ol li + li) {
        margin-top: 0.35rem;
      }

      @media (max-width: 720px) {
        :root {
          --masthead-height: 6.6rem;
        }

        .masthead,
        .content {
          padding: 1.1rem;
        }

        .masthead {
          padding: 0 1.1rem;
        }

        .masthead-top {
          display: flex;
          align-items: flex-start;
          justify-content: flex-start;
          flex-direction: column;
          gap: 0;
          padding: 0.75rem 0;
        }

        .nav {
          width: 100%;
          justify-content: flex-start;
        }

        .brand-wordmark {
          white-space: normal;
        }

        .nav a {
          height: auto;
          padding: 0.8rem 0.95rem 0.65rem;
          margin-bottom: 0;
        }

        .site-search {
          width: 100%;
          max-width: none;
          min-width: 0;
        }

        .site-search-panel {
          left: 0;
          width: 100%;
          transform: none;
        }

        .content {
          grid-template-columns: 1fr;
          gap: 1rem;
        }

        :global(body.route-docs-concepts-what-is-causality .prose h3 + p + ul > li > em:first-child) {
          display: block;
          width: auto;
          margin-right: 0;
          margin-bottom: 0.35rem;
        }

        .sidebar {
          position: static;
          padding-top: 0;
        }

        .sidebar-scroll {
          position: static;
          width: auto;
          max-height: none;
          overflow: visible;
          padding-right: 0;
        }

        .toc {
          display: none;
        }
      }
    </style>
  </head>
  <body class={routeClass}>
    <div class="shell">
      <div class="frame">
        <header class="masthead">
          <div class="masthead-top">
            <a class="brand" href="/docs/overview" aria-label="Causal Agent Protocol">
              <img class="brand-mark" src="/icons/cap-logo-c-sharp.svg" alt="" aria-hidden="true" />
              <span class="brand-wordmark">Causal Agent Protocol</span>
            </a>
            <div class="site-search" data-site-search data-open="false">
              <label>
                <span class="sr-only">Search docs and spec</span>
                <input
                  class="site-search-input"
                  type="search"
                  placeholder="Search docs and spec"
                  aria-label="Search docs and spec"
                  autocomplete="off"
                  spellcheck="false"
                  data-search-input
                />
              </label>
              <div class="site-search-panel" data-search-panel hidden>
                <div class="site-search-empty" data-search-empty>Search by concept, verb, field name, or page title.</div>
                <div class="site-search-results" data-search-results></div>
              </div>
            </div>
            <nav class="nav" aria-label="Primary">
              {
                topNav.map((item) => (
                  <a href={item.href} data-active={item.active}>
                    {item.label}
                  </a>
                ))
              }
            </nav>
          </div>
          <div class="masthead-copy">
            <h1>Causal Agent Protocol</h1>
            <p>{description ?? "Capability disclosure, invocation, and provenance for causal reasoning systems."}</p>
          </div>
        </header>
        <main class="content" data-left={sidebar.length > 0} data-right={toc.length > 0}>
          {
            sidebar.length > 0 && (
              <aside class="sidebar" aria-label="Sidebar">
                <div class="sidebar-scroll">
                  {sidebar.map((group) => (
                    <section class="sidebar-group">
                      <h2>{group.title}</h2>
                      {group.links.map((link) => (
                        <a href={link.route} data-active={currentRoute === link.route}>
                          {link.title}
                        </a>
                      ))}
                    </section>
                  ))}
                </div>
              </aside>
            )
          }
          <div class="main">
            <div class="prose">
              <slot />
            </div>
          </div>
          {
            toc.length > 0 && (
              <aside class="toc" aria-label="On this page">
                <h2>On This Page</h2>
                {toc.map((item) => (
                  <a href={`#${item.id}`} data-depth={item.depth}>
                    {item.text}
                  </a>
                ))}
              </aside>
            )
          }
        </main>
      </div>
    </div>
  </body>
</html>

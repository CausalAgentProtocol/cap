---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "./BaseLayout.css";
import { ClientRouter } from "astro:transitions";
import PageActions from "../components/PageActions.astro";
import { getSearchIndex, type SidebarGroup, type SpecVersionSwitcher, type TocHeading } from "../lib/site";
import { buildMarkdownRoute, getTopNav, siteShell } from "../lib/site-shell";

interface Props {
  title: string;
  currentRoute: string;
  currentSection?: string;
  description?: string;
  seoDescription?: string;
  noindex?: boolean;
  sidebar?: SidebarGroup[];
  toc?: TocHeading[];
  specVersionSwitcher?: SpecVersionSwitcher;
}

const {
  title,
  currentRoute,
  currentSection,
  description,
  seoDescription,
  noindex = false,
  sidebar = [],
  toc = [],
  specVersionSwitcher
} = Astro.props;
const routeClass = `route-${currentRoute.replace(/^\//, "").replace(/[^a-z0-9]+/gi, "-").replace(/^-+|-+$/g, "") || "home"}`;
const searchIndexJson = JSON.stringify(await getSearchIndex()).replace(/</g, "\\u003c");
const topNav = getTopNav(currentRoute, currentSection);
const markdownUrl = buildMarkdownRoute(currentRoute);
const activeSidebarGroup = sidebar.find((group) => group.links.some((link) => link.route === currentRoute));
const pageSectionLabel = activeSidebarGroup?.title;
const siteOrigin = Astro.site ?? new URL(siteShell.siteUrl);
const pageTitle = `${title} | ${siteShell.titleSuffix}`;
const pageDescription = seoDescription ?? description ?? siteShell.defaultDescription;
const canonicalUrl = new URL(currentRoute, siteOrigin).toString();
const socialImageUrl = new URL(siteShell.brandIconPath, siteOrigin).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const openGraphType = currentSection === "documentation" || currentSection === "specification" ? "article" : "website";
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  isPartOf: {
    "@type": "WebSite",
    name: siteShell.brandWordmark,
    url: siteOrigin.toString()
  }
}).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/icons/cap-logo-c-sharp-transparent.svg" />
    <meta property="og:site_name" content={siteShell.brandWordmark} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <script type="application/ld+json" set:html={structuredData}></script>
    <ClientRouter />
    <script id="site-search-index" type="application/json" set:html={searchIndexJson}></script>
    <script>
      import { initSiteLayout } from "../lib/browser/init.ts";

      initSiteLayout();
    </script>
  </head>
  <body class={routeClass}>
    <div class="shell">
      <div class="frame">
        <header class="masthead">
          <div class="masthead-top">
            <div class="masthead-primary">
              <a class="brand" href={siteShell.brandHref} aria-label={siteShell.brandWordmark}>
                <img class="brand-mark" src={siteShell.brandIconPath} alt="" aria-hidden="true" />
                <span class="brand-wordmark">{siteShell.brandWordmark}</span>
              </a>
              <nav class="nav" aria-label="Primary">
                {
                  topNav.map((item) => (
                    <a href={item.href} data-active={item.active}>
                      {item.label}
                    </a>
                  ))
                }
              </nav>
            </div>
            <div class="masthead-utility">
              {
                specVersionSwitcher && (
                  <div class="spec-version-dropdown" data-spec-version-dropdown data-open="false">
                    <button
                      class="spec-version-trigger"
                      type="button"
                      data-spec-version-toggle
                      aria-haspopup="menu"
                      aria-expanded="false"
                      aria-label={`Specification version: ${specVersionSwitcher.currentVersion}`}
                    >
                      <span class="spec-version-trigger-label">{specVersionSwitcher.currentVersion}</span>
                      <svg
                        class="spec-version-trigger-icon"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.7"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="m7 10 5 5 5-5"></path>
                      </svg>
                    </button>
                    <div class="spec-version-menu" role="menu" hidden data-spec-version-menu>
                      {specVersionSwitcher.links.map((link) => (
                        <a
                          class="spec-version-item"
                          href={link.href}
                          role="menuitem"
                          data-spec-version-link
                          data-active-version={link.active ? "true" : undefined}
                        >
                          <span class="spec-version-item-main">{link.label}</span>
                          <span class="spec-version-status">{link.status === "active" ? "Active" : "Draft"}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                )
              }
              <div class="site-search" data-site-search data-open="false">
                <label>
                  <span class="sr-only">{siteShell.searchLabel}</span>
                  <svg
                    class="site-search-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                  </svg>
                  <input
                    class="site-search-input"
                    type="search"
                    placeholder={siteShell.searchPlaceholder}
                    aria-label={siteShell.searchLabel}
                    autocomplete="off"
                    spellcheck="false"
                    data-search-input
                  />
                </label>
                <div class="site-search-panel" data-search-panel hidden>
                  <div class="site-search-empty" data-search-empty>Search by concept, verb, field name, or page title.</div>
                  <div class="site-search-results" data-search-results></div>
                </div>
              </div>
              <a
                class="github-link"
                href={siteShell.githubHref}
                target="_blank"
                rel="noreferrer"
                aria-label="GitHub"
                title="GitHub"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 .5C5.65.5.5 5.66.5 12.03c0 5.1 3.3 9.43 7.88 10.96.58.11.79-.25.79-.56 0-.28-.01-1.2-.02-2.17-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.78 2.7 1.27 3.36.97.1-.75.4-1.27.72-1.56-2.56-.29-5.26-1.29-5.26-5.73 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.17 1.18a10.93 10.93 0 0 1 5.77 0c2.2-1.49 3.16-1.18 3.16-1.18.64 1.59.24 2.77.12 3.06.74.81 1.19 1.84 1.19 3.1 0 4.45-2.7 5.44-5.28 5.72.41.36.77 1.06.77 2.14 0 1.55-.01 2.79-.01 3.17 0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.03C23.5 5.66 18.35.5 12 .5Z" />
                </svg>
              </a>
            </div>
          </div>
          <div class="masthead-copy">
            <h1>{siteShell.brandWordmark}</h1>
            <p>{description ?? siteShell.defaultDescription}</p>
          </div>
        </header>
        <main class="content" data-left={sidebar.length > 0} data-right={toc.length > 0}>
          {
            sidebar.length > 0 && (
              <aside class="sidebar" aria-label="Sidebar">
                <div class="sidebar-scroll">
                  {sidebar.map((group) => (
                    <section class="sidebar-group">
                      <h2>{group.title}</h2>
                      {group.links.map((link) => (
                        <a href={link.route} data-active={currentRoute === link.route}>
                          {link.title}
                        </a>
                      ))}
                    </section>
                  ))}
                </div>
              </aside>
            )
          }
          <div class="main">
            <div class="page-header">
              {pageSectionLabel && <span class="page-header-meta">{pageSectionLabel}</span>}
              <div class="page-header-top">
                <div class="page-header-heading">
                  <h1 class="page-header-title" data-page-title>{title}</h1>
                </div>
                <div class="page-header-copy">
                  <PageActions markdownUrl={markdownUrl} />
                </div>
              </div>
            </div>
            <div class="prose">
              <slot />
            </div>
          </div>
          {
            toc.length > 0 && (
              <aside class="toc" aria-label="On this page">
                <h2>On This Page</h2>
                {toc.map((item) => (
                  <a href={`#${item.id}`} data-depth={item.depth}>
                    {item.text}
                  </a>
                ))}
              </aside>
            )
          }
        </main>
      </div>
    </div>
  </body>
</html>

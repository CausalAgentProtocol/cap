---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSidebarGroups, getSiteMap, renderRoute, routeToSlug } from "../lib/site";

export async function getStaticPaths() {
  const siteMap = await getSiteMap();

  const routes = siteMap.routes.map((entry) => ({
    params: { slug: routeToSlug(entry.route) },
    props: { route: entry.route }
  }));

  if (import.meta.env.DEV) {
    routes.push(
      { params: { slug: undefined }, props: { route: "/docs/overview" } },
      { params: { slug: "docs" }, props: { route: "/docs/overview" } }
    );
  }

  return routes;
}

const { route } = Astro.props;
const rendered = await renderRoute(route);
const sidebar = await getSidebarGroups(route);
---

<BaseLayout
  title={rendered.pageTitle}
  currentRoute={rendered.entry.route}
  currentSection={rendered.entry.section}
  sidebar={sidebar}
  toc={rendered.toc}
  description="Repository markdown rendered through the CAP site route map."
>
  <Fragment set:html={rendered.html} />
</BaseLayout>
